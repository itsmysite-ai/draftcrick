{
  "name": "draftplay",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "clean": "turbo clean",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @draftplay/db db:studio",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:web": "playwright test --project=web",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:cricket": "playwright test tests/e2e/cricket-story/ --project=mobile --workers=1",
    "test:e2e:cricket:auth": "playwright test tests/e2e/cricket-story/01-auth.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:onboarding": "playwright test tests/e2e/cricket-story/02-onboarding.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:home": "playwright test tests/e2e/cricket-story/03-home-explore.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:league": "playwright test tests/e2e/cricket-story/04-league-create.spec.ts tests/e2e/cricket-story/05-league-join.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:team": "playwright test tests/e2e/cricket-story/06-team-builder.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:contest": "playwright test tests/e2e/cricket-story/07-contest-lifecycle.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:draft": "playwright test tests/e2e/cricket-story/08-draft-room.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:auction": "playwright test tests/e2e/cricket-story/09-auction-room.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:live": "playwright test tests/e2e/cricket-story/10-match-live.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:settlement": "playwright test tests/e2e/cricket-story/12-settlement.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:guru": "playwright test tests/e2e/cricket-story/13-guru-ai.spec.ts --project=mobile --workers=1",
    "test:e2e:cricket:profile": "playwright test tests/e2e/cricket-story/14-profile-settings.spec.ts --project=mobile --workers=1",
    "test:unit": "npx tsx tests/unit/scoring.test.ts && npx tsx tests/e2e/cricket-story/11-scoring-engine.spec.ts",
    "test:unit:scoring": "npx tsx tests/unit/scoring.test.ts",
    "test:unit:scoring-engine": "npx tsx tests/e2e/cricket-story/11-scoring-engine.spec.ts",
    "test:cricket:full": "npx tsx tests/e2e/cricket-story/11-scoring-engine.spec.ts && playwright test tests/e2e/cricket-story/ --project=mobile --workers=1",
    "db:local": "./scripts/local-db.sh start",
    "db:local:stop": "./scripts/local-db.sh stop",
    "db:local:psql": "./scripts/local-db.sh psql",
    "emulator": "npx firebase emulators:start --only auth --project demo-draftcrick",
    "dev:all": "npx concurrently --names emu,api,web,app --prefix-colors yellow,cyan,magenta,green \"pnpm emulator\" \"sleep 2 && pnpm --filter @draftplay/api dev\" \"sleep 2 && pnpm --filter @draftplay/web dev\" \"sleep 4 && pnpm --filter @draftplay/mobile dev\"",
    "expo:prod": "cd apps/mobile && cp .env.local .env.local.bak && cp ../../.env.expo-prod .env.local && trap 'mv .env.local.bak .env.local' EXIT && npx expo start --clear",
    "test:emulator": "node scripts/test-with-emulator.js",
    "test:type-check": "turbo type-check",
    "test:regression": "node scripts/test-regression.js",
    "test:compare": "node scripts/compare-regression.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@expo/metro-runtime": "~5.0.4",
      "react-native-worklets": "0.5.1"
    }
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2"
  }
}
