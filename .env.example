# ===========================================
# DraftCrick Environment Variables
# ===========================================

# Database (Cloud SQL PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/draftcrick

# Redis (Memorystore)
REDIS_URL=redis://localhost:6379

# Firebase Auth (server-side — firebase-admin SDK on API server)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Firebase Auth (client-side — Expo requires EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Firebase Auth Emulator (set to localhost:9099 for local dev/test)
EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=

# Payments — Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ELITE=

# Payments — Stripe (future)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cricket Data API
CRICAPI_KEY=
SPORTRADAR_KEY=

# Google Cloud
GCP_PROJECT_ID=draftcrick-prod
GCP_REGION=asia-south1

# Vertex AI / Gemini
GOOGLE_CLOUD_API_KEY=
GEMINI_API_KEY=

# Resend (Email)
RESEND_API_KEY=

# Sentry
SENTRY_DSN=

# App
NODE_ENV=development
PORT=3001
WEB_URL=http://localhost:3000
MOBILE_URL=exp://localhost:8081
